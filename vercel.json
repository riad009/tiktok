{
    "version": 2,
    "builds": [
        {
            "src": "server/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "build/web/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/server/index.js"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "/server/index.js"
        },
        {
            "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json|wasm|map))",
            "dest": "/build/web/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/build/web/index.html"
        }
    ]
}