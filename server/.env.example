# Artistcase Server — Environment Variables
# Copy this file to .env and fill in your real values

# ── Mux Video API (https://dashboard.mux.com/settings/access-tokens)
MUX_TOKEN_ID=your_mux_token_id_here
MUX_TOKEN_SECRET=your_mux_token_secret_here

# ── Redis (optional — used for real-time viewer counts)
# Leave blank to skip Redis and use in-memory fallback
REDIS_URL=

# ── JWT (for auth)
JWT_SECRET=your_jwt_secret_here

# ── Server port
PORT=3001
